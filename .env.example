# Database Configuration
# IMPORTANT: Modifier ce mot de passe avant le déploiement
POSTGRES_USER=radiotherapy
POSTGRES_PASSWORD=VotreMotDePasseSecurise123!
POSTGRES_DB=radiotherapy_db

# Backend Configuration
# Utiliser le même mot de passe que celui défini ci-dessus
DATABASE_URL=postgresql://radiotherapy:VotreMotDePasseSecurise123!@db:5432/radiotherapy_db

# CORS - Domaines autorisés à accéder à l'API
# En production sur CentraleSupélec, utiliser: https://dosimetrie.centralesupelec.fr
CORS_ORIGINS=http://localhost:3000,https://dosimetrie.centralesupelec.fr

# Port Configuration (80 for HTTP, 443 for HTTPS)
PORT=80
